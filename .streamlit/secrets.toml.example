# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml must NEVER be committed -- it is listed in .gitignore.
#
# Local development: Streamlit reads this file automatically.
# Deployed (Streamlit Community Cloud): paste the same keys into
# the app's "Secrets" settings in the dashboard instead of this file.

MISTRAL_API_KEY = "your-mistral-api-key-here"
TAVILY_API_KEY = "your-tavily-api-key-here"
